{
  "PreToolUse": [
    {
      "matcher": "^Bash$",
      "hooks": [
        {
          "type": "command",
          "command": "/usr/bin/python3 .codex/hooks/pre_tool_use_policy.py",
          "timeout": 15
        }
      ]
    }
  ],
  "PermissionRequest": [
    {
      "matcher": "^Bash$",
      "hooks": [
        {
          "type": "command",
          "command": "/usr/bin/python3 .codex/hooks/permission_request.py",
          "timeout": 15
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "/usr/bin/python3 .codex/hooks/stop_require_verification.py",
          "timeout": 15
        }
      ]
    }
  ]
}
